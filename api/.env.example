# --- CHE1 Dashboard BFF ------------------------------------------------------
# Copy this file to `.env` (next to the Go binary or in the repo root) and
# fill in real values for production.

# HTTP
ADDR=:8080
# Where the frontend is served from (used in redirects + CORS allowlist).
FRONTEND_URL=http://localhost:5173
# Comma-separated additional origins allowed to call /api. Leave empty to
# default to FRONTEND_URL.
ALLOWED_ORIGINS=

# --- Discord OAuth ----------------------------------------------------------
# Create an application at https://discord.com/developers/applications and
# copy the Client ID + Client Secret. Set the OAuth2 redirect URI to match
# DISCORD_REDIRECT_URI below.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/api/auth/callback

# Bot token — used to check which guilds the CHE1 bot is in so the UI can
# show "Invite Bot" vs "Manage". Same token the Bot process uses.
DISCORD_BOT_TOKEN=

# --- Dev stub --------------------------------------------------------------
# When DEV_MODE=true AND DISCORD_CLIENT_ID is empty, /api/auth/login bypasses
# Discord and logs in as a seeded demo user. Never enable in production.
DEV_MODE=false

# --- Postgres --------------------------------------------------------------
# Same database the Bot + Worker use. Schema is migrated on boot (idempotent).
DATABASE_URL=postgres://che1:che1@localhost:5432/che1?sslmode=disable

# --- Worker bridge ---------------------------------------------------------
# Outbound calls from the dashboard BFF into the CHE1 Worker. Leave WORKER_URL
# empty in environments where no Worker is running (actions will still be
# recorded in dash_history; they just won't execute in Discord).
WORKER_URL=http://localhost:8081
# Must match Worker's INBOUND_API_KEY.
WORKER_API_KEY=

# --- Bot-facing API --------------------------------------------------------
# Bearer token the Bot sends when calling /api/bot/*. Must match the Bot's
# DASHBOARD_API_KEY. Treat as a secret.
DASHBOARD_API_KEY=

# --- Cookies ---------------------------------------------------------------
# Set to true when serving over HTTPS so session cookies are flagged Secure.
SESSION_SECURE_COOKIES=false

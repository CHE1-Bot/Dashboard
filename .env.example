# docker-compose .env — root-level, consumed by docker compose up
# Copy to `.env` and fill in real values.

# Discord application (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_REDIRECT_URI=http://localhost:8080/api/auth/callback

# Shared secrets between dashboard <-> worker <-> bot
# Generate strong random values, e.g. `openssl rand -hex 32`
WORKER_API_KEY=
DASHBOARD_API_KEY=

# Where the browser talks to the dashboard (matches published port on host).
FRONTEND_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080
SESSION_SECURE_COOKIES=false

# Optional Bot dev guild (instant slash-command publish)
GUILD_ID=
